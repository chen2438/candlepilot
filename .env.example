# Runtime mode: backtest | paper-production-data | binance-testnet
CANDLEPILOT_MODE=paper-production-data
CANDLEPILOT_HOST=127.0.0.1
CANDLEPILOT_PORT=8000
CANDLEPILOT_DATABASE_URL=sqlite+aiosqlite:///./candlepilot.db
CANDLEPILOT_DATA_DIR=./data
CANDLEPILOT_LLM_TIMEOUT=45
# Decision cadences to analyze (comma-separated subset of 1m,5m,15m).
# Also selectable at runtime from the console before starting the engine.
CANDLEPILOT_CADENCES=1m,5m,15m

# Optional LLM model and reasoning effort. Leave empty to use each CLI's default.
# Also settable at runtime from the console before starting the engine.
# Codex effort: minimal | low | medium | high
CANDLEPILOT_CODEX_MODEL=
CANDLEPILOT_CODEX_REASONING_EFFORT=
# Claude model alias (e.g. sonnet, opus) or full name; effort: low | medium | high | xhigh | max
CANDLEPILOT_CLAUDE_MODEL=
CANDLEPILOT_CLAUDE_EFFORT=

# Only required when CANDLEPILOT_MODE=binance-testnet.
# Never use production Binance credentials here.
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=


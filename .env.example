# Runtime mode: backtest | paper-production-data | binance-testnet
CANDLEPILOT_MODE=paper-production-data
CANDLEPILOT_HOST=127.0.0.1
CANDLEPILOT_PORT=8000
CANDLEPILOT_DATABASE_URL=sqlite+aiosqlite:///./candlepilot.db
CANDLEPILOT_DATA_DIR=./data
CANDLEPILOT_LLM_TIMEOUT=45
# Maximum age of the analysis snapshot before a fresh pre-trade quote is allowed.
CANDLEPILOT_MAX_SNAPSHOT_AGE_SECONDS=75
# Decision cadences to analyze (comma-separated subset of 5m,15m,30m).
# Also selectable at runtime from the console before starting the engine.
CANDLEPILOT_CADENCES=5m,15m,30m
# Top-ranked candidates analyzed per cadence cycle (1-20, default 5).
# Also adjustable at runtime from the console before starting the engine.
CANDLEPILOT_CANDIDATES_PER_CYCLE=5
# Optional run limits. Whichever is reached first gracefully stops the engine.
# Leave empty for unbounded. Also settable from the console before starting.
CANDLEPILOT_MAX_RUN_SECONDS=
CANDLEPILOT_MAX_RUN_COST_USD=

# Optional ordered provider route. The first ready provider is primary; later entries are fallbacks.
# Supported aliases: codex | claude-code | openai-compatible. Leave empty for console selection.
CANDLEPILOT_PROVIDER_CHAIN=
# Legacy single-provider fallback, used only when PROVIDER_CHAIN is empty.
CANDLEPILOT_DEFAULT_PROVIDER=

# Optional LLM model and reasoning effort. Leave empty to use each CLI's default.
# Also settable at runtime from the console before starting the engine.
# Codex effort: minimal | low | medium | high
CANDLEPILOT_CODEX_MODEL=
CANDLEPILOT_CODEX_REASONING_EFFORT=
# Claude model alias (e.g. sonnet, opus) or full name; effort: low | medium | high | xhigh | max
CANDLEPILOT_CLAUDE_MODEL=
CANDLEPILOT_CLAUDE_EFFORT=

# Optional user-supplied OpenAI-compatible endpoints. base_url is the API root that
# precedes /chat/completions or /responses. External endpoints must use HTTPS;
# http:// is accepted only for localhost/127.0.0.1/::1. Keep real keys only in this
# ignored .env file or an exported environment variable.
# Custom API endpoints (up to 8). JSON array; each entry needs a unique lowercase
# id and base_url, and becomes the provider "openai-compatible:<id>" (addressable
# in a chain as "custom:<id>"). Optional per entry: api_key, model,
# reasoning_effort, wire_api (chat-completions | responses), require_api_key,
# extra_headers. Example:
# CANDLEPILOT_CUSTOM_LLM_PROVIDERS_JSON=[{"id":"groq","base_url":"https://api.groq.com/openai/v1","api_key":"gsk_...","model":"llama-3.3-70b-versatile"},{"id":"local","base_url":"http://127.0.0.1:1234/v1","model":"qwen","require_api_key":false}]
CANDLEPILOT_CUSTOM_LLM_PROVIDERS_JSON=

# Only required when CANDLEPILOT_MODE=binance-testnet.
# Never use production Binance credentials here.
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
